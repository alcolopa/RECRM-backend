# Server Configuration
# --------------------
PORT=3000
# The secret key used to sign JWT tokens. Keep this secure!
JWT_SECRET=your-super-secret-key-change-me

# Database Configuration
# ----------------------
# PostgreSQL connection string. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://realestate:realestate@localhost:5432/realestate?schema=public"

# File Upload Configuration
# -------------------------
# Options: 'local' or 's3'
# 'local' saves files to the /backend/uploads directory.
# 's3' uses AWS S3 bucket for storage.
UPLOAD_DESTINATION=local

# AWS S3 Configuration (Required only if UPLOAD_DESTINATION=s3)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
# Public URL for generating file links. 
# Local default: http://localhost:3000/uploads
# S3 example: https://your-bucket.s3.amazonaws.com
AWS_S3_PUBLIC_URL=http://localhost:3000/uploads

# Email Configuration
# -------------------
# Options: 'smtp' or 'resend'
EMAIL_PROVIDER=smtp

# Resend Configuration (Required only if EMAIL_PROVIDER=resend)
RESEND_API_KEY=re_123456789

# SMTP Configuration (Required only if EMAIL_PROVIDER=smtp)
# For Gmail: smtp.gmail.com, Port 587
# For Mailtrap: sandbox.smtp.mailtrap.io, Port 2525
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# For Gmail, use an "App Password" not your primary password
SMTP_PASS=your-app-password
# The 'From' address shown to recipients
SMTP_FROM=noreply@yourdomain.com

# Frontend Integration
# --------------------
# The URL where the frontend application is running (used for email links)
FRONTEND_URL=http://localhost:5173
# The suffix used for organization workspaces (e.g., orgname.estatehub.com)
WORKSPACE_SUFFIX=.estatehub.com
