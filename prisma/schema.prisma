generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id             String             @id @default(uuid())
  name           String
  slug           String             @unique
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  address        String?
  email          String?
  logo           String?
  phone          String?
  website        String?
  ownerId        String
  accentColor    String             @default("EMERALD")
  defaultTheme   OrganizationTheme  @default(LIGHT)
  activities     Activity[]
  calendarEvents CalendarEvent[]
  contacts       Contact[]
  customRoles    CustomRole[]
  deals          Deal[]
  files          File[]
  invitations    Invitation[]
  leads          Lead[]
  memberships    Membership[]
  notes          Note[]
  offers         Offer[]
  negotiations   OfferNegotiation[]
  owner          User               @relation("OrganizationOwner", fields: [ownerId], references: [id])
  properties     Property[]
  tags           Tag[]
  tasks          Task[]
  commissionConfig CommissionConfig?

  @@index([id])
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  password            String
  firstName           String?
  lastName            String?
  avatar              String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  unitPreference      UnitPreference     @default(METRIC)
  phone               String?
  completedTutorials  String[]           @default([])
  dashboardConfig     Json?
  preferredTheme      ThemePreference    @default(SYSTEM)
  resetToken          String?
  resetTokenExpires   DateTime?
  createdActivities   Activity[]         @relation("CreatedBy")
  calendarEvents      CalendarEvent[]    @relation("UserCalendar")
  assignedContacts    Contact[]          @relation("AssignedAgent")
  assignedDeals       Deal[]             @relation("AssignedUser")
  sentInvitations     Invitation[]       @relation("Inviter")
  assignedLeads       Lead[]             @relation("AssignedUser")
  memberships         Membership[]
  createdNotes        Note[]             @relation("CreatedBy")
  createdOffers       Offer[]            @relation("CreatedBy")
  offerHistory        OfferHistory[]     @relation("HistoryUser")
  createdNegotiations OfferNegotiation[] @relation("CreatedBy")
  ownedOrganizations  Organization[]     @relation("OrganizationOwner")
  assignedProperties  Property[]         @relation("PropertyAgent")
  createdProperties   Property[]         @relation("PropertyCreatedBy")
  assignedTasks       Task[]             @relation("AssignedUser")
  createdTasks        Task[]             @relation("TaskCreator")
  agentCommissionConfig AgentCommissionConfig?

  @@index([email])
}

model CustomRole {
  id             String        @id @default(uuid())
  name           String
  description    String?
  permissions    Permission[]
  level          Int           @default(1)
  isSystem       Boolean       @default(false)
  organizationId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitations    Invitation[]
  memberships    Membership[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Invitation {
  id             String           @id @default(uuid())
  email          String
  organizationId String
  inviterId      String
  role           UserRole         @default(AGENT)
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  customRoleId   String?
  customRole     CustomRole?      @relation(fields: [customRoleId], references: [id])
  inviter        User             @relation("Inviter", fields: [inviterId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
}

model Membership {
  id             String       @id @default(uuid())
  role           UserRole     @default(AGENT)
  userId         String
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  customRoleId   String?
  customRole     CustomRole?  @relation(fields: [customRoleId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

model Contact {
  id                String             @id @default(uuid())
  organizationId    String
  firstName         String
  lastName          String
  email             String?
  phone             String
  secondaryPhone    String?
  type              ContactType
  leadSource        String?
  assignedAgentId   String?
  status            ContactStatus      @default(NEW)
  notes             String?
  tags              String[]           @default([])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastContactedAt   DateTime?
  activities        Activity[]
  buyerProfile      BuyerProfile?
  calendarEvents    CalendarEvent[]
  assignedAgent     User?              @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals             Deal[]
  entityTags        EntityTag[]
  convertedFromLead Lead?              @relation("LeadToContact")
  contactNotes      Note[]             @relation("ContactNotes")
  negotiations      OfferNegotiation[]
  ownedProperties   Property[]         @relation("PropertyOwner")
  sellerProfile     SellerProfile?

  @@index([organizationId])
  @@index([email])
  @@index([assignedAgentId])
}

model BuyerProfile {
  id                     String           @id @default(uuid())
  contactId              String           @unique
  minBudget              Decimal?
  maxBudget              Decimal?
  financingType          FinancingType?
  preApproved            Boolean          @default(false)
  preApprovedAmount      Decimal?
  downPayment            Decimal?
  propertyTypes          PropertyType[]   @default([])
  minBedrooms            Int?
  minBathrooms           Float?
  minArea                Float?
  maxArea                Float?
  preferredCities        String[]         @default([])
  preferredNeighborhoods String[]         @default([])
  parkingRequired        Boolean          @default(false)
  gardenRequired         Boolean          @default(false)
  furnished              Boolean          @default(false)
  newConstruction        Boolean          @default(false)
  buyingTimeline         BuyingTimeline?
  purchasePurpose        PurchasePurpose?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  contact                Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model SellerProfile {
  id                 String            @id @default(uuid())
  contactId          String            @unique
  minimumPrice       Decimal?
  mortgageBalance    Decimal?
  listingType        ListingType?
  readyToList        Boolean           @default(false)
  occupied           Boolean           @default(false)
  tenantLeaseEndDate DateTime?
  sellingTimeline    SellingTimeline?
  reasonForSelling   ReasonForSelling?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  properties         Property[]        @relation("SellerProperty")
  contact            Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Lead {
  id                 String             @id @default(uuid())
  firstName          String
  lastName           String
  email              String?
  phone              String?
  status             LeadStatus         @default(NEW)
  source             String?
  organizationId     String
  assignedUserId     String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  budget             Decimal?
  convertedAt        DateTime?
  convertedContactId String?            @unique
  notes              String?
  preferredLocation  String?
  propertyType       PropertyType?
  activities         Activity[]         @relation("LeadActivities")
  calendarEvents     CalendarEvent[]
  tags               EntityTag[]
  assignedUser       User?              @relation("AssignedUser", fields: [assignedUserId], references: [id])
  convertedContact   Contact?           @relation("LeadToContact", fields: [convertedContactId], references: [id])
  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  negotiations       OfferNegotiation[]

  @@index([organizationId])
  @@index([assignedUserId])
  @@index([email])
}

model Property {
  id               String             @id @default(uuid())
  organizationId   String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // --- 1. Core Info ---
  title            String
  description      String?
  type             PropertyType       @default(HOUSE)
  listingType      PropertyListingType?
  status           PropertyStatus     @default(AVAILABLE)
  referenceCode    String?            @unique
  createdById      String?

  // --- 2. Location ---
  address          String
  country          String?
  city             String?
  state            String?
  governorate      String?
  district         String?
  street           String?
  buildingName     String?
  floor            String?
  unitNumber       String?
  zipCode          String?
  latitude         Float?
  longitude        Float?

  // --- 3. Property Specifications ---
  sizeSqm          Float?
  landSizeSqm      Float?
  bedrooms         Int?
  bathrooms        Float?
  area             Float?
  lotSize          Float?
  livingRooms      Int?
  kitchens         Int?
  parkingSpaces    Int?
  floorNumber      Int?
  totalFloors      Int?
  yearBuilt        Int?
  condition        PropertyCondition?
  furnished        Boolean?           @default(false)

  // --- 4. Pricing & Financials (Common) ---
  price            Decimal?
  currency         String?            @default("USD")
  negotiable       Boolean?           @default(false)

  // Pricing (Sale)
  pricePerSqm              Decimal?
  commissionBuyerPercent   Float?
  commissionSellerPercent  Float?
  paymentTerms             Json?

  // Pricing (Rent)
  rentalPeriod             RentalPeriod?
  rentAmount               Decimal?
  paymentFrequency         PaymentFrequency?
  advancePaymentMonths     Int?
  securityDeposit          Decimal?
  minLeaseDurationMonths   Int?
  maxLeaseDurationMonths   Int?
  utilitiesIncluded        Boolean?       @default(false)
  availableFrom            DateTime?
  renewalTerms             String?

  // Pricing (Lease / Commercial)
  leaseTermYears           Int?
  rentEscalation           String?
  fitOutPeriod             String?
  serviceCharges           Decimal?
  insuranceRequired        Boolean?       @default(false)
  maintenanceResponsibility MaintenanceResponsibility?

  // --- 5. Legal & Ownership ---
  ownerName                String?
  ownerContactId           String?
  ownershipType            OwnershipType?
  titleDeedAvailable       Boolean?       @default(false)
  zoningType               ZoningType?
  legalNotes               String?

  // --- 6. Features ---
  features         String[]

  // --- 7. CRM Fields ---
  assignedUserId   String?
  sellerProfileId  String?
  source           PropertySource?
  listingDate      DateTime?
  expiryDate       DateTime?
  priority         PropertyPriority?
  propertyTags     String[]           @default([])

  // --- 8. Activity Tracking ---
  viewsCount       Int                @default(0)
  inquiriesCount   Int                @default(0)
  lastViewedAt     DateTime?

  // --- Relations ---
  deals            Deal[]
  tags             EntityTag[]
  negotiations     OfferNegotiation[]
  assignedUser     User?              @relation("PropertyAgent", fields: [assignedUserId], references: [id])
  createdBy        User?              @relation("PropertyCreatedBy", fields: [createdById], references: [id])
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sellerProfile    SellerProfile?     @relation("SellerProperty", fields: [sellerProfileId], references: [id])
  ownerContact     Contact?           @relation("PropertyOwner", fields: [ownerContactId], references: [id])
  propertyFeatures PropertyFeature[]
  propertyImages   PropertyImage[]

  @@index([organizationId])
  @@index([referenceCode])
  @@index([listingType])
  @@index([status])
}

model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model OfferNegotiation {
  id             String            @id @default(uuid())
  status         NegotiationStatus @default(ACTIVE)
  organizationId String
  propertyId     String
  contactId      String
  leadId         String?
  createdById    String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  offers         Offer[]
  contact        Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy      User              @relation("CreatedBy", fields: [createdById], references: [id])
  lead           Lead?             @relation(fields: [leadId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([propertyId])
  @@index([contactId])
}

model Offer {
  id             String           @id @default(uuid())
  price          Decimal
  deposit        Decimal?
  financingType  FinancingType
  closingDate    DateTime?
  expirationDate DateTime?
  status         OfferStatus
  notes          String?
  negotiationId  String
  organizationId String
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  offerer        OffererType      @default(BUYER)
  type           DealType         @default(SALE)
  
  buyerCommission  Decimal?
  sellerCommission Decimal?
  agentCommission  Decimal?
  
  createdBy      User             @relation("CreatedBy", fields: [createdById], references: [id])
  negotiation    OfferNegotiation @relation(fields: [negotiationId], references: [id], onDelete: Cascade)
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  history        OfferHistory[]

  @@index([organizationId])
  @@index([createdById])
  @@index([negotiationId])
}

model OfferHistory {
  id        String       @id @default(uuid())
  action    OfferAction
  field     String?
  oldValue  String?
  newValue  String?
  offerId   String
  userId    String
  createdAt DateTime     @default(now())
  offerer   OffererType?
  offer     Offer        @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user      User         @relation("HistoryUser", fields: [userId], references: [id])

  @@index([offerId])
}

model Deal {
  id             String       @id @default(uuid())
  title          String
  value          Decimal?
  stage          DealStage    @default(DISCOVERY)
  organizationId String
  contactId      String?
  propertyId     String?
  assignedUserId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedUser   User?        @relation("AssignedUser", fields: [assignedUserId], references: [id])
  contact        Contact?     @relation(fields: [contactId], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property       Property?    @relation(fields: [propertyId], references: [id])
  tags           EntityTag[]

  type              DealType @default(SALE)
  propertyPrice     Decimal?
  rentPrice         Decimal?
  buyerCommission   Decimal?
  sellerCommission  Decimal?
  totalCommission   Decimal?
  agentCommission   Decimal?
  isAgentPaid       Boolean   @default(false)
  agentPaidAt       DateTime?

  commissionOverride DealCommissionOverride?

  @@index([organizationId])
  @@index([assignedUserId])
}

model Activity {
  id             String       @id @default(uuid())
  type           ActivityType @default(NOTE)
  subject        String
  content        String?
  organizationId String
  contactId      String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  leadId         String?
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("CreatedBy", fields: [createdById], references: [id])
  lead           Lead?        @relation("LeadActivities", fields: [leadId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Task {
  id              String         @id @default(uuid())
  title           String
  description     String?
  status          TaskStatus     @default(TODO)
  dueDate         DateTime?
  organizationId  String
  assignedUserId  String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdById     String?
  priority        TaskPriority   @default(MEDIUM)
  calendarEventId String?        @unique
  assignedUser    User?          @relation("AssignedUser", fields: [assignedUserId], references: [id])
  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id])
  createdBy       User?          @relation("TaskCreator", fields: [createdById], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([assignedUserId])
  @@index([createdById])
}

model CalendarEvent {
  id             String            @id @default(uuid())
  title          String
  description    String?
  startTime      DateTime
  endTime        DateTime
  type           CalendarEventType @default(MEETING)
  organizationId String
  userId         String
  contactId      String?
  leadId         String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  contact        Contact?          @relation(fields: [contactId], references: [id])
  lead           Lead?             @relation(fields: [leadId], references: [id])
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User              @relation("UserCalendar", fields: [userId], references: [id], onDelete: Cascade)
  task           Task?

  @@index([organizationId])
  @@index([userId])
  @@index([startTime, endTime])
}

model Note {
  id             String       @id @default(uuid())
  content        String
  organizationId String
  contactId      String?
  createdById    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  contact        Contact?     @relation("ContactNotes", fields: [contactId], references: [id], onDelete: Cascade)
  createdBy      User?        @relation("CreatedBy", fields: [createdById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model File {
  id             String       @id @default(uuid())
  name           String
  url            String
  mimeType       String?
  size           Int?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Tag {
  id             String       @id @default(uuid())
  name           String
  color          String?
  organizationId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  entityTags     EntityTag[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
}

model EntityTag {
  id         String    @id @default(uuid())
  tagId      String
  contactId  String?
  leadId     String?
  propertyId String?
  dealId     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  contact    Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal       Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lead       Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tag        Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@index([tagId])
  @@index([contactId])
  @@index([leadId])
  @@index([propertyId])
  @@index([dealId])
}

model Feature {
  id               String            @id @default(uuid())
  name             String            @unique
  category         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  propertyFeatures PropertyFeature[]
}

model PropertyFeature {
  id         String   @id @default(uuid())
  propertyId String
  featureId  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  feature    Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, featureId])
  @@index([propertyId])
  @@index([featureId])
}

model CommissionConfig {
  id                    String   @id @default(uuid())
  organizationId        String   @unique

  // RENT
  rentBuyerValue        Float?
  rentBuyerType         CommissionType @default(MULTIPLIER)
  rentSellerValue       Float?
  rentSellerType        CommissionType @default(MULTIPLIER)
  rentAgentValue        Float?
  rentAgentType         CommissionType @default(PERCENTAGE)

  // SALE
  saleBuyerValue        Float?
  saleBuyerType         CommissionType @default(PERCENTAGE)
  saleSellerValue       Float?
  saleSellerType        CommissionType @default(PERCENTAGE)
  saleAgentValue        Float?
  saleAgentType         CommissionType @default(PERCENTAGE)

  paymentTiming         String?
  paymentMethod         String?

  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model AgentCommissionConfig {
  id                    String   @id @default(uuid())
  agentId               String   @unique

  // RENT overrides
  rentAgentValue        Float?
  rentAgentType         CommissionType?

  // SALE overrides
  saleAgentValue        Float?
  saleAgentType         CommissionType?

  monthlyTarget         Decimal?

  agent                 User @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model DealCommissionOverride {
  id                    String   @id @default(uuid())
  dealId                String   @unique

  buyerCommission       Decimal?
  sellerCommission      Decimal?
  agentCommission       Decimal?

  notes                 String?

  deal                  Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)
}

enum CommissionType {
  PERCENTAGE
  FIXED
  MULTIPLIER
}

enum DealType {
  SALE
  RENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum Permission {
  LEADS_VIEW
  LEADS_CREATE
  LEADS_EDIT
  LEADS_DELETE
  LEADS_EXPORT
  CONTACTS_VIEW
  CONTACTS_CREATE
  CONTACTS_EDIT
  CONTACTS_DELETE
  CONTACTS_EXPORT
  PROPERTIES_VIEW
  PROPERTIES_CREATE
  PROPERTIES_EDIT
  PROPERTIES_DELETE
  DEALS_VIEW
  DEALS_CREATE
  DEALS_EDIT
  DEALS_DELETE
  TEAM_VIEW
  TEAM_INVITE
  TEAM_EDIT_ROLES
  TEAM_REMOVE_MEMBER
  ORG_SETTINGS_EDIT
  ORG_BILLING_VIEW
  DASHBOARD_VIEW
  PAYOUTS_VIEW
  PAYOUTS_MANAGE
  TASKS_VIEW
  TASKS_VIEW_ALL
  TASKS_CREATE
  TASKS_ASSIGN_ANY
  TASKS_EDIT
  TASKS_DELETE
  CALENDAR_VIEW
  CALENDAR_VIEW_ALL
  CALENDAR_EDIT
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CalendarEventType {
  MEETING
  CALL
  SITE_VISIT
  BLOCKER
  OTHER
}

enum UserRole {
  OWNER
  ADMIN
  AGENT
  SUPPORT
}

enum UnitPreference {
  METRIC
  IMPERIAL
}

enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
}

enum OrganizationTheme {
  LIGHT
  DARK
}

enum ContactStatus {
  NEW
  CONTACTED
  QUALIFIED
  ACTIVE
  INACTIVE
  LOST
}

enum ContactType {
  BUYER
  SELLER
  BOTH
}

enum FinancingType {
  CASH
  MORTGAGE
  PRIVATE_FINANCING
  OTHER
}

enum BuyingTimeline {
  ASAP
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  SIX_PLUS_MONTHS
  JUST_LOOKING
}

enum PurchasePurpose {
  PRIMARY_RESIDENCE
  INVESTMENT
  VACATION_HOME
  RELOCATION
}

enum ListingType {
  EXCLUSIVE
  NON_EXCLUSIVE
}

enum SellingTimeline {
  ASAP
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  SIX_PLUS_MONTHS
  JUST_EXPLORING
}

enum ReasonForSelling {
  UPGRADE
  RELOCATION
  INVESTMENT_EXIT
  FINANCIAL_NEED
  DIVORCE
  INHERITANCE
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  LOST
  CLOSED_WON
}

enum DealStage {
  DISCOVERY
  QUALIFICATION
  PRESENTATION
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum PropertyStatus {
  AVAILABLE
  RESERVED
  SOLD
  RENTED
  OFF_MARKET
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  OFFICE
  SHOP
  LAND
  WAREHOUSE
  BUILDING
}

enum PropertyListingType {
  SALE
  RENT
  LEASE
}

enum PropertyCondition {
  NEW
  GOOD
  NEEDS_RENOVATION
  UNDER_CONSTRUCTION
}

enum OwnershipType {
  FREEHOLD
  LEASEHOLD
}

enum ZoningType {
  RESIDENTIAL
  COMMERCIAL
  MIXED
}

enum RentalPeriod {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum PaymentFrequency {
  MONTHLY
