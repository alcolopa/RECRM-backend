generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- Enums ---

enum UserRole {
  OWNER
  ADMIN
  AGENT
  SUPPORT
}

enum UnitPreference {
  METRIC
  IMPERIAL
}

enum ContactStatus {
  NEW
  CONTACTED
  QUALIFIED
  ACTIVE
  INACTIVE
  LOST
}

enum ContactType {
  BUYER
  SELLER
}

enum FinancingType {
  CASH
  MORTGAGE
}

enum BuyingTimeline {
  ASAP
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  SIX_PLUS_MONTHS
  JUST_LOOKING
}

enum PurchasePurpose {
  PRIMARY_RESIDENCE
  INVESTMENT
  VACATION_HOME
  RELOCATION
}

enum ListingType {
  EXCLUSIVE
  NON_EXCLUSIVE
}

enum SellingTimeline {
  ASAP
  ONE_TO_THREE_MONTHS
  THREE_TO_SIX_MONTHS
  SIX_PLUS_MONTHS
  JUST_EXPLORING
}

enum ReasonForSelling {
  UPGRADE
  RELOCATION
  INVESTMENT_EXIT
  FINANCIAL_NEED
  DIVORCE
  INHERITANCE
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  LOST
  CLOSED_WON
}

enum DealStage {
  DISCOVERY
  QUALIFICATION
  PRESENTATION
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum PropertyStatus {
  AVAILABLE
  UNDER_CONTRACT
  SOLD
  RENTED
  OFF_MARKET
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  CONDO
  TOWNHOUSE
  LAND
  COMMERCIAL
  OFFICE
  RETAIL
  INDUSTRIAL
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  SITE_VISIT
  NOTE
}

// --- Entities ---

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  address     String?
  phone       String?
  email       String?
  website     String?
  logo        String?      // URL or key to logo file
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ownerId     String?  @unique
  owner       User?    @relation("OrganizationOwner", fields: [ownerId], references: [id])

  users       User[]   @relation("OrganizationUsers")
  contacts    Contact[]
  leads       Lead[]
  properties  Property[]
  deals       Deal[]
  activities  Activity[]
  tasks       Task[]
  notes       Note[]
  files       File[]
  tags        Tag[]

  @@index([id])
}

model User {
  id              String       @id @default(uuid())
  email           String       @unique
  password        String
  firstName       String?
  lastName        String?
  avatar          String?      // URL to profile picture
  phone           String?      // Agent phone number
  role            UserRole     @default(AGENT)
  unitPreference  UnitPreference @default(METRIC)
  organizationId  String
  organization    Organization @relation("OrganizationUsers", fields: [organizationId], references: [id], onDelete: Cascade)
  
  ownedOrganization Organization? @relation("OrganizationOwner")
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  assignedLeads      Lead[]     @relation("AssignedUser")
  assignedDeals      Deal[]     @relation("AssignedUser")
  assignedTasks      Task[]     @relation("AssignedUser")
  assignedProperties Property[] @relation("PropertyAgent")
  createdActivities  Activity[] @relation("CreatedBy")
  createdNotes       Note[]     @relation("CreatedBy")
  assignedContacts   Contact[]  @relation("AssignedAgent")

  @@index([organizationId])
  @@index([email])
}

model Contact {
  id              String       @id @default(uuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  email           String?
  phone           String
  secondaryPhone  String?
  type            ContactType
  leadSource      String?
  assignedAgentId String?
  assignedAgent   User?        @relation("AssignedAgent", fields: [assignedAgentId], references: [id], onDelete: SetNull)
  status          ContactStatus @default(NEW)
  notes           String?      @db.Text
  tags            String[]     @default([])
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  lastContactedAt DateTime?

  buyerProfile    BuyerProfile?
  sellerProfile   SellerProfile?
  
  deals           Deal[]
  activities      Activity[]
  contactNotes    Note[]       @relation("ContactNotes")
  entityTags      EntityTag[]

  @@index([organizationId])
  @@index([email])
  @@index([assignedAgentId])
}

model BuyerProfile {
  id                String         @id @default(uuid())
  contactId         String         @unique
  contact           Contact        @relation(fields: [contactId], references: [id], onDelete: Cascade)
  minBudget         Decimal?
  maxBudget         Decimal?
  financingType     FinancingType?
  preApproved       Boolean        @default(false)
  preApprovedAmount Decimal?
  downPayment       Decimal?

  // Preferences
  propertyTypes     PropertyType[] @default([])
  minBedrooms       Int?
  minBathrooms      Float?
  minArea           Float?
  maxArea           Float?

  // Location
  preferredCities        String[] @default([])
  preferredNeighborhoods String[] @default([])

  // Lifestyle
  parkingRequired   Boolean @default(false)
  gardenRequired    Boolean @default(false)
  furnished         Boolean @default(false)
  newConstruction   Boolean @default(false)

  // Timeline & Motivation
  buyingTimeline    BuyingTimeline?
  purchasePurpose   PurchasePurpose?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SellerProfile {
  id                String           @id @default(uuid())
  contactId         String           @unique
  contact           Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  minimumPrice      Decimal?
  mortgageBalance   Decimal?

  // Sale Conditions
  listingType       ListingType?
  readyToList       Boolean          @default(false)
  occupied          Boolean          @default(false)
  tenantLeaseEndDate DateTime?

  // Timeline & Motivation
  sellingTimeline   SellingTimeline?
  reasonForSelling  ReasonForSelling?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  properties        Property[]       @relation("SellerProperty")
}

model Lead {
  id              String       @id @default(uuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  status          LeadStatus   @default(NEW)
  source          String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUserId  String?
  assignedUser    User?        @relation("AssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tags            EntityTag[]

  @@index([organizationId])
  @@index([assignedUserId])
  @@index([email])
}

model Property {
  id              String         @id @default(uuid())
  title           String
  description     String?
  address         String
  city            String?
  state           String?
  zipCode         String?
  country         String?
  governorate     String?
  price           Decimal?
  status          PropertyStatus @default(AVAILABLE)
  type            PropertyType   @default(HOUSE)
  bedrooms        Int?
  bathrooms       Float?
  area            Float?         // Square footage or meters
  lotSize         Float?
  yearBuilt       Int?
  features        String[]       // Legacy field, kept for backward compat
  propertyImages  PropertyImage[]
  propertyFeatures PropertyFeature[]
  organizationId  String
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  assignedUserId  String?
  assignedUser    User?          @relation("PropertyAgent", fields: [assignedUserId], references: [id], onDelete: SetNull)
  sellerProfileId String?
  sellerProfile   SellerProfile? @relation("SellerProperty", fields: [sellerProfileId], references: [id], onDelete: SetNull)
  deals           Deal[]
  tags            EntityTag[]

  @@index([organizationId])
  }model PropertyImage {
  id         String   @id @default(uuid())
  url        String
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([propertyId])
}

model Deal {
  id              String       @id @default(uuid())
  title           String
  value           Decimal?
  stage           DealStage    @default(DISCOVERY)
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?     @relation(fields: [contactId], references: [id], onDelete: SetNull)
  propertyId      String?
  property        Property?    @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  assignedUserId  String?
  assignedUser    User?        @relation("AssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tags            EntityTag[]

  @@index([organizationId])
  @@index([assignedUserId])
}

model Activity {
  id              String       @id @default(uuid())
  type            ActivityType @default(NOTE)
  subject         String
  content         String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdById     String?
  createdBy       User?        @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
}

model Task {
  id              String       @id @default(uuid())
  title           String
  description     String?
  status          TaskStatus   @default(TODO)
  dueDate         DateTime?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedUserId  String?
  assignedUser    User?        @relation("AssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([assignedUserId])
}

model Note {
  id              String       @id @default(uuid())
  content         String
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         Contact?     @relation("ContactNotes", fields: [contactId], references: [id], onDelete: Cascade)
  createdById     String?
  createdBy       User?        @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
}

model File {
  id              String       @id @default(uuid())
  name            String
  url             String
  mimeType        String?
  size            Int?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
}

model Tag {
  id              String       @id @default(uuid())
  name            String
  color           String?
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  entityTags      EntityTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model EntityTag {
  id          String   @id @default(uuid())
  tagId       String
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  // Relations to different entities (polymorphic-ish with explicit relations)
  contactId   String?
  contact     Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  leadId      String?
  lead        Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  dealId      String?
  deal        Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tagId])
  @@index([contactId])
  @@index([leadId])
  @@index([propertyId])
  @@index([dealId])
}

model Feature {
  id              String           @id @default(uuid())
  name            String           @unique
  category        String?          // e.g. "Amenities", "Utilities", "Security"
  createdAt       DateTime         @default(now())

  propertyFeatures PropertyFeature[]
}

model PropertyFeature {
  id          String   @id @default(uuid())
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  featureId   String
  feature     Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([propertyId, featureId])
  @@index([propertyId])
  @@index([featureId])
}
